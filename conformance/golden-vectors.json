        "did": "did:k0nsult:claude:opus-4.7-1m:META_JUDGE",
        "subject_type": "agent",
        "provider": "claude",
        "model": "opus-4.7-1m",
        "role": "judge",
        "public_key": { "type": "ed25519", "value": "MCowBQYDK2VwAyEAexamplePublicKeyBase64OnlyNoSecret==" },
        "soulbound_token": {
          "token_id": "sbt:k0nsult:8f3a1c",
          "non_transferable": true,
          "issued_at": "2026-07-19T00:00:00Z",
          "reputation_score": 74,
