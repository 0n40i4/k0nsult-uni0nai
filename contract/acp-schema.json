{
  "@context": "https://k0nsult.dev/schema/acp/1.0",
  "protocol": "acp",
  "version": "1.0",
  "name": "Agent Communication Protocol",
  "description": "Machine-first protocol for K0NSULT agent interactions",
  "layers": {
    "1_protocol": {
      "description": "Schema, version, signing",
      "fields": ["protocol", "version", "signature", "message_id"]
    },
    "2_context": {
      "description": "State, session, parent",
      "fields": ["context", "session_id", "state_hash", "previous_message_id"]
    },
    "3_constraint": {
      "description": "Permissions, latency, cost",
      "fields": ["permissions", "max_latency_ms", "max_cost_usd", "required_verification"]
    },
    "4_intent": {
      "description": "Action, params, outcome",
      "fields": ["type", "params", "expected_outcome"]
    }
  },
  "message_format": {
    "protocol": "acp/1.0",
    "message_id": "uuid-v4",
    "timestamp": "ISO8601",
    "sender": {
      "did": "did:k0nsult:acme:model-v2:executor",
      "role": "executor|orchestrator|judge"
    },
    "intent": {
      "type": "query",
      "params": {}
    },
    "context": {
      "session_id": "string",
      "state_hash": "sha256:hex"
    },
    "signature": "base64-ed25519-sig"
  }
}
